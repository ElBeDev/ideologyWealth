    <script>
        (function ($) {
            "use strict";
            var form = $("#subscribeForm");
            form.on('submit', function (e) {
                e.preventDefault();
                var data = form.serialize();
                $.ajax({
                    url: `https://1lifefinancial.com/subscribe`,
                    method: 'post',
                    data: data,
                    success: function (response) {
                        if (response.success) {
                            form.find('input[name=email]').val('');
                            notify('success', response.message);
                        }else{
                            notify('error', response.error);
                        }
                    }
                });
            });

        })(jQuery);
    </script>

  
    <script>
        "use strict";
        (function ($) {


            

            $(".langSel").on("change", function() {
                window.location.href = "https://1lifefinancial.com/change/"+$(this).val();
            });

            let myModal = document.getElementById('cookieModal');
                            myModal.classList.remove('show');
            
            $('.cookie-modal .close-btn').on('click', function(){
                $('#cookieModal').removeClass('show');
            });

            $('.cookie-accept').on('click', function(){
                $.get("https://1lifefinancial.com/cookie/accept",
                    function (response) {
                        if(response.success){
                            notify('success', response.success);
                            $('#cookieModal').removeClass('show');
                        }
                    }
                );
            });

        })(jQuery);
    </script>

  <link rel="stylesheet" href="./1life Financial - FAQ_files/iziToast.min.css">
<script src="./1life Financial - FAQ_files/iziToast.min.js"></script>

<script>
    "use strict";
        function notify(status, message) {
            if(typeof message == 'string'){
                iziToast[status]({
                    message: message,
                    position: "topRight"
                });
            }else{
                $.each(message, function(i, val) {
                    iziToast[status]({
                        message: val,
                        position: "topRight"
                    });
                });
            }

        }
</script>


  



  <!-- PWA Service Worker Registration -->
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('./service-worker.js')
          .then((registration) => {
            console.log('Service Worker registered successfully:', registration.scope);
          })
          .catch((error) => {
            console.log('Service Worker registration failed:', error);
          });
      });
    }

    // PWA Install Prompt
    let deferredPrompt;
    const installButton = document.getElementById('pwa-install-btn');
    
    window.addEventListener('beforeinstallprompt', (e) => {
      e.preventDefault();
      deferredPrompt = e;
      if (installButton) {
        installButton.style.display = 'flex';
        console.log('PWA Install button shown');
      }
    });

    if (installButton) {
      installButton.addEventListener('click', async () => {
        if (!deferredPrompt) {
          alert('Esta aplicación ya está instalada o tu navegador no soporta instalación PWA.');
          return;
        }
        deferredPrompt.prompt();
        const { outcome } = await deferredPrompt.userChoice;
        console.log(`User response: ${outcome}`);
        deferredPrompt = null;
        installButton.style.display = 'none';
      });
    }

    window.addEventListener('appinstalled', () => {
      console.log('PWA installed');
      if (installButton) installButton.style.display = 'none';
      alert('¡Aplicación instalada exitosamente!');
    });

    if (window.matchMedia('(display-mode: standalone)').matches) {
      document.body.classList.add('pwa-mode');
    }
  </script>

  <!-- PWA Styles -->
  <style>
    .pwa-install-button {
      position: fixed; bottom: 30px; right: 30px;
      background: linear-gradient(135deg, #6fb950 0%, #0143a3 100%);
      color: white; border: none; border-radius: 50px;
      padding: 15px 30px; font-size: 16px; font-weight: 600;
      cursor: pointer; box-shadow: 0 10px 30px rgba(111, 185, 80, 0.4);
      z-index: 9999; display: flex; align-items: center; gap: 10px;
      transition: all 0.3s ease; animation: pulse-install 2s infinite;
    }
    .pwa-install-button:hover {
      transform: translateY(-5px) scale(1.05);
      box-shadow: 0 15px 40px rgba(111, 185, 80, 0.6);
    }
    .pwa-install-button i { font-size: 20px; animation: bounce-icon 1s infinite; }
    @keyframes pulse-install {
      0%, 100% { box-shadow: 0 10px 30px rgba(111, 185, 80, 0.4); }
      50% { box-shadow: 0 10px 40px rgba(111, 185, 80, 0.7); }
    }
    @keyframes bounce-icon {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-3px); }
    }
    @media (max-width: 768px) {
      .pwa-install-button { bottom: 20px; right: 20px; padding: 12px 20px; font-size: 14px; }
      .pwa-install-button span { display: none; }
      .pwa-install-button i { font-size: 24px; }
    }
    .custom--bg, .btn-primary, .btn--base { background: #6fb950 !important; }
    .custom--cl, .feature-card i, .text--base { color: #6fb950 !important; }
    .overview-section, .footer { background: #0143a3 !important; }
  </style>

  

