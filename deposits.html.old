<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Deposits - 1life Financial</title>
    <link rel="stylesheet" href="1life Financial - My Deposits_files/bootstrap.min.css">
    <link rel="stylesheet" href="1life Financial - My Deposits_files/all.min.css">
    <link rel="stylesheet" href="1life Financial - My Deposits_files/line-awesome.min.css">
    <link rel="stylesheet" href="1life Financial - My Deposits_files/lightcase.css">
    <link rel="stylesheet" href="1life Financial - My Deposits_files/slick.css">
    <link rel="stylesheet" href="1life Financial - My Deposits_files/custom.css">
    <link rel="stylesheet" href="1life Financial - My Deposits_files/main.css">
    <link rel="stylesheet" href="1life Financial - My Deposits_files/color.php">
    <link rel="stylesheet" href="1life Financial - My Deposits_files/iziToast.min.css">
</head>
<body>
    <div class="main-wrapper">
        <header class="header">
            <div class="header__bottom">
                <div class="container">
                    <nav class="navbar navbar-expand-xl p-0 align-items-center">
                        <a class="site-logo site-title" href="index.html">
                            <img src="1life Financial - My Deposits_files/logo.png" alt="logo">
                        </a>
                        <button class="navbar-toggler ml-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent">
                            <span class="menu-toggle"></span>
                        </button>
                        <div class="collapse navbar-collapse mt-lg-0 mt-3" id="navbarSupportedContent">
                            <ul class="navbar-nav main-menu ml-auto">
                                <li><a href="dashboard.html">Dashboard</a></li>
                                <li><a class="active" href="deposits.html">Deposit</a></li>
                                <li><a href="withdrawals.html">TRANSFER</a></li>
                                <li><a href="profile.html">More</a></li>
                            </ul>
                            <div class="nav-right">
                                <a href="#" onclick="logout()" class="btn btn-sm btn--base text-white">
                                    <i class="las la-sign-out-alt"></i> Logout
                                </a>
                            </div>
                        </div>
                    </nav>
                </div>
            </div>
        </header>

        <section class="pt-120 pb-120">
            <div class="container">
                <div class="row">
                    <div class="col-lg-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center mb-4">
                                    <h4 class="mb-0">My Deposits</h4>
                                    <button type="button" class="btn btn--base text-white" data-bs-toggle="modal" data-bs-target="#depositModal">
                                        <i class="las la-plus"></i> New Deposit
                                    </button>
                                </div>

                                <div class="table-responsive">
                                    <table class="table table-striped custom--table">
                                        <thead>
                                            <tr>
                                                <th>Transaction ID</th>
                                                <th>Gateway</th>
                                                <th>Date</th>
                                                <th>Amount</th>
                                                <th>Charge</th>
                                                <th>Final Amount</th>
                                                <th>Status</th>
                                            </tr>
                                        </thead>
                                        <tbody id="depositsTableBody">
                                            <tr>
                                                <td colspan="7" class="text-center">
                                                    <div class="spinner-border text-primary" role="status">
                                                        <span class="visually-hidden">Loading...</span>
                                                    </div>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <!-- Deposit Modal -->
    <div class="modal fade" id="depositModal" tabindex="-1" aria-labelledby="depositModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="depositModalLabel">Make a Deposit</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="depositForm">
                        <div class="mb-3">
                            <label for="depositAmount" class="form-label">Amount (USD) *</label>
                            <input type="number" class="form-control" id="depositAmount" name="amount" required min="1" step="0.01">
                            <small class="text-muted">A 2% fee will be added to your deposit amount.</small>
                        </div>
                        <div class="mb-3">
                            <label for="depositMethod" class="form-label">Payment Method *</label>
                            <select class="form-control" id="depositMethod" name="method" required>
                                <option value="">Select Method</option>
                                <option value="bank_transfer">Bank Transfer</option>
                                <option value="credit_card">Credit Card</option>
                                <option value="paypal">PayPal</option>
                                <option value="crypto">Cryptocurrency</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="depositNotes" class="form-label">Notes (Optional)</label>
                            <textarea class="form-control" id="depositNotes" name="notes" rows="3"></textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn--base text-white" onclick="submitDeposit()">Submit Deposit</button>
                </div>
            </div>
        </div>
    </div>

    <!-- jQuery library -->
    <script src="1life Financial - My Deposits_files/jquery-3.5.1.min.js"></script>
    <script src="1life Financial - My Deposits_files/bootstrap.bundle.min.js"></script>
    <script src="1life Financial - My Deposits_files/iziToast.min.js"></script>

    <script>
        function notify(s,m){iziToast[s]({message:m,position:"topRight"});}
        function logout(){localStorage.clear();window.location.href='login.html';}

        function loadDeposits() {
            $.ajax({
                url: '/api/deposits.php',
                method: 'GET',
                success: function(data) {
                    if (data.success) {
                        displayDeposits(data.deposits);
                    } else {
                        $('#depositsTableBody').html('<tr><td colspan="7" class="text-center">No deposits found</td></tr>');
                    }
                },
                error: function() {
                    $('#depositsTableBody').html('<tr><td colspan="7" class="text-center text-danger">Error loading deposits</td></tr>');
                }
            });
        }

        function displayDeposits(deposits) {
            const tbody = $('#depositsTableBody');
            tbody.empty();

            if (!deposits || deposits.length === 0) {
                tbody.html('<tr><td colspan="7" class="text-center">No deposits found. Click "New Deposit" to get started.</td></tr>');
                return;
            }

            deposits.forEach(function(deposit) {
                const statusBadge = getStatusBadge(deposit.status);
                const date = new Date(deposit.created_at).toLocaleDateString();
                
                const row = `
                    <tr>
                        <td><span class="fw-bold text--base">${deposit.trx}</span></td>
                        <td>${deposit.gateway || 'N/A'}</td>
                        <td>${date}</td>
                        <td><span class="text-success">$${parseFloat(deposit.amount).toFixed(2)}</span></td>
                        <td><span class="text-warning">$${parseFloat(deposit.charge).toFixed(2)}</span></td>
                        <td><span class="fw-bold text--base">$${parseFloat(deposit.final_amount).toFixed(2)}</span></td>
                        <td>${statusBadge}</td>
                    </tr>
                `;
                tbody.append(row);
            });
        }

        function getStatusBadge(status) {
            const badges = {
                'pending': '<span class="badge bg-warning text-dark">Pending</span>',
                'approved': '<span class="badge bg-success">Approved</span>',
                'rejected': '<span class="badge bg-danger">Rejected</span>'
            };
            return badges[status] || '<span class="badge bg-secondary">Unknown</span>';
        }

        function submitDeposit() {
            const amount = $('#depositAmount').val();
            const method = $('#depositMethod').val();
            const notes = $('#depositNotes').val();

            if (!amount || !method) {
                notify('error', 'Please fill all required fields');
                return;
            }

            if (parseFloat(amount) < 1) {
                notify('error', 'Minimum deposit amount is $1.00');
                return;
            }

            $.ajax({
                url: '/api/deposits.php',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    amount: amount,
                    method: method,
                    notes: notes
                }),
                success: function(data) {
                    if (data.success) {
                        notify('success', 'Deposit request submitted successfully');
                        $('#depositModal').modal('hide');
                        $('#depositForm')[0].reset();
                        loadDeposits();
                    } else {
                        notify('error', data.message || 'Error submitting deposit');
                    }
                },
                error: function() {
                    notify('error', 'Connection error. Please try again.');
                }
            });
        }

        if(localStorage.getItem('logged_in')!=='true')window.location.href='login.html';
        else loadDeposits();
    </script>
</body>
</html>
